# WhatsApp (código de país + número, sin + ni espacios)
EXPO_PUBLIC_WHATSAPP_NUMBER=

# Panel admin móvil (solo validación local — configurar en .env, no subir al repo)
EXPO_PUBLIC_ADMIN_USERNAME=
EXPO_PUBLIC_ADMIN_PASSWORD=

# Catálogo remoto (opcional). Por defecto usa el catálogo empaquetado en assets/catalog/
# EXPO_PUBLIC_USE_REMOTE_CATALOG=true
# EXPO_PUBLIC_CATALOG_API=
# EXPO_PUBLIC_CATALOG_IMAGE_BASE=
