# Catálogo solo local (sin backend):
# VITE_USE_API=false

# Con backend: Vite reenvía /api al proxy configurado en VITE_DEV_API_PROXY.
VITE_USE_API=false
VITE_API_BASE_URL=/api

# WhatsApp (código de país + número, sin + ni espacios). Configurar en tu .env local.
VITE_WHATSAPP_NUMBER=

# Solo desarrollo con API: URL del backend para el proxy /api (ej. http://127.0.0.1:PUERTO)
# VITE_DEV_API_PROXY=
